{
  "manifest_version": 3,
  "name": "拉线共享助手",
  "version": "2.6.10",
  "description": "批量共享+批量开摄像头",
  "permissions": ["tabs", "activeTab", "scripting", "windows", "system.display"],
  "host_permissions": [
    "https://www.messenger.com/*",
    "https://www.facebook.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.messenger.com/*",
        "https://www.facebook.com/*"
      ],
      "js": ["inject.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.messenger.com/*",
        "https://www.facebook.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
